{
  "name": "wa-transfer",
  "version": "1.0.0",
  "description": "WhatsApp & WhatsApp Business Chat Migration Tool",
  "author": "WA Transfer",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"vite --port 3737 --strictPort\" \"wait-on http://localhost:3737 && electron .\"",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "lint": "eslint main/ renderer/",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "adb-ts": "^6.2.0",
    "adm-zip": "^0.5.0",
    "axios": "^1.0.0",
    "better-sqlite3": "^9.0.0",
    "bplist-parser": "^0.3.0",
    "plist": "^3.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "concurrently": "^8.0.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.0.0",
    "lucide-react": "^0.383.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.watransfer.app",
    "productName": "WA Transfer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "main/**",
      "assets/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      "assets/apk-cache/**"
    ]
  }
}
